# ── BrickPlan backend-go configuration ──
# Copy to .env and fill in. SECRET_KEY MUST be a random string of >=32 chars.

APP_ENV=development
HTTP_ADDR=127.0.0.1:8100

# A random >=32-char secret. The server refuses to start with the built-in default.
# Generate one: openssl rand -hex 32
SECRET_KEY=please-generate-a-32-plus-char-random-secret-value

# JWT lifetimes
JWT_ACCESS_MIN=30
JWT_REFRESH_DAYS=7

# MySQL DSN (production uses a real password, not the one below)
MYSQL_DSN=brickplans:brickplans@tcp(127.0.0.1:3306)/brickplans?charset=utf8mb4&parseTime=True&loc=UTC

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage: local | tencent_cos
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# Tencent COS (only when STORAGE_BACKEND=tencent_cos)
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=
TENCENT_COS_PUBLIC_BASE_URL=

# Email verification (SMTP). Leave SMTP_HOST empty in dev to log verification
# links to the server console instead of sending mail.
APP_BASE_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
